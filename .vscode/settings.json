{
  "workbench.colorTheme": "Abyss",
  "circuitpython.board.version": null,
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.diagnosticSeverityOverrides": {
    "reportMissingModuleSource": "none",
    "reportMissingImports": "none",
    "reportUnknownMemberType": "none"
  },
  "python.analysis.typeshedPaths": [
    "${workspaceFolder}/typings/"
  ],
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv-pimaroni-inky-frame/bin/python",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.autoSearchPaths": [
    "${workspaceFolder}",
    "${workspaceFolder}/typings"
  ],
  "python.languageServer": "None",
  "micropico.pyIgnore": ".git,.venv-pimaroni-inky-frame,.vscode,__pycache__,*.pyc,typings",
  "files.exclude": {
      ".venv-*": true,       // Excludes python virtual environments
      ".git": true,          // Excludes git directory
      ".vscode": true,       // Excludes VS Code directory
      "typings": true,       // Excludes typings directory
      "__pycache__": true,   // Excludes python cache
      "build": true,         // Excludes build artifacts
      ".ruff_cache": true    // Excludes ruff cache
    }
}